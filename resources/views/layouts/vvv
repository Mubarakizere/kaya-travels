    /* âœ… Hero Styles */
    .hero-slide {
      height: 80vh;
      background-size: cover;
      background-position: center;
      position: relative;
      display: flex;
      align-items: center;
      padding: 0 10%;
    }

    .hero-slide::before {
      content: "";
      position: absolute;
      inset: 0;
      background: rgba(0, 0, 0, 0.5);
    }

    .hero-content {
      position: relative;
      z-index: 2;
      color: white;
      max-width: 600px;
    }

    .hero-content h1 {
      font-size: 2.8rem;
      font-weight: bold;
      color: var(--gold);
    }

    .hero-content p {
      font-size: 1.1rem;
      color: white;
    }

    @media (max-width: 768px) {
      .hero-slide {
        height: 80vh;
        padding: 0 5%;
        text-align: center;
        justify-content: center;
      }

      .hero-content h1 {
        font-size: 2rem;
      }

      .hero-content p {
        font-size: 1rem;
      }
    }

    /* âœ… Floating Search Bar */
    .search-bar-wrapper {
      margin-top: -60px;
      position: relative;
      z-index: 10;
    }

    .form-select {
      background-color: #000 !important;
      color: #fff !important;
      border: 1px solid #333 !important;
    }

    .form-label {
      font-weight: 500;
      font-size: 0.95rem;
    }

    @media (max-width: 768px) {
      .search-bar-wrapper {
        margin-top: -40px;
      }

      .search-bar-wrapper .row {
        padding: 1.5rem;
      }
