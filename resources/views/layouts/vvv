  }
.navbar-nav {
  display: flex;
  flex-wrap: nowrap; /* ðŸš« Prevent wrapping */
  white-space: nowrap;
}
  .navbar-brand {
    font-weight: bold;
    color: var(--gold) !important;
  }

  .navbar-nav .nav-link {
    color: white !important;
    margin: 0 10px;
